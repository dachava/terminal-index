---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
  readingTime?: string;
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  readingTime,
  prevPost,
  nextPost,
} = Astro.props;

const formattedPub = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpd = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <article class="blog-post">
    <header class="post-header container">
      <div class="post-breadcrumb">
        <a href="/blog">← blog</a>
        <span aria-hidden="true"> / </span>
        <span>{title}</span>
      </div>

      <div class="post-meta">
        <time datetime={pubDate.toISOString()} class="post-date-full">
          {formattedPub}
        </time>
        {readingTime && (
          <span class="reading-time">· {readingTime} read</span>
        )}
        {updatedDate && (
          <span class="updated-date">
            · updated <time datetime={updatedDate.toISOString()}>{formattedUpd}</time>
          </span>
        )}
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>

      {tags.length > 0 && (
        <div class="post-tags">
          <TagList tags={tags} linkPrefix="/blog?tag=" />
        </div>
      )}
    </header>

    {heroImage && (
      <div class="post-hero container">
        <img src={heroImage} alt="" role="presentation" class="hero-image" />
      </div>
    )}

    <div class="post-body container">
      <div class="window">
        <div class="window-titlebar">
          <div class="window-dots">
            <span class="window-dot window-dot-close" aria-hidden="true"></span>
            <span class="window-dot window-dot-min" aria-hidden="true"></span>
            <span class="window-dot window-dot-max" aria-hidden="true"></span>
          </div>
          <span class="window-title">{title}.mdx</span>
        </div>
        <div class="window-body prose">
          <slot />
        </div>
      </div>
    </div>

    <nav class="post-nav container" aria-label="Post navigation">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="post-nav-link prev">
          <span class="nav-label">← previous</span>
          <span class="nav-title">{prevPost.title}</span>
        </a>
      ) : <div></div>}

      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="post-nav-link next">
          <span class="nav-label">next →</span>
          <span class="nav-title">{nextPost.title}</span>
        </a>
      ) : <div></div>}
    </nav>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: var(--space-12) 0;
  }

  .post-header {
    max-width: 780px;
    margin-bottom: var(--space-8);
  }

  .post-breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .post-breadcrumb a {
    color: var(--color-cyan);
    text-decoration: none;
  }

  .post-breadcrumb a:hover { text-decoration: underline; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    margin-bottom: var(--space-4);
  }

  .post-title {
    font-size: var(--text-4xl);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    line-height: 1.15;
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .post-hero {
    max-width: 780px;
    margin-bottom: var(--space-8);
  }

  .hero-image {
    width: 100%;
    border: 1px solid var(--color-border-bright);
    border-radius: var(--radius-sm);
  }

  .post-body {
    max-width: 780px;
    margin-bottom: var(--space-12);
  }

  .post-body .window-body {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-nav {
    max-width: 780px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: border-color var(--transition-fast);
  }

  .post-nav-link:hover {
    border-color: var(--color-cyan);
    text-decoration: none;
  }

  .post-nav-link.next { text-align: right; }

  .nav-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .nav-title {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .post-title { font-size: var(--text-2xl); }
    .post-nav { grid-template-columns: 1fr; }
  }
</style>
