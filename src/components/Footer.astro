---
import HitCounter from './HitCounter.astro';

const year = new Date().getFullYear();

const socials = [
  { label: 'GitHub',   href: 'https://github.com/yourname',    icon: '[gh]'  },
  { label: 'Twitter',  href: 'https://twitter.com/yourname',   icon: '[tw]'  },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourname', icon: '[in]' },
  { label: 'Email',    href: 'mailto:hello@yourname.dev',       icon: '[✉]'  },
  { label: 'RSS',      href: '/rss.xml',                        icon: '[rss]' },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-chrome">
    <div class="footer-titlebar" aria-hidden="true">
      <span class="footer-status">
        <span class="status-dot"></span>
        online · {year}
      </span>
      <span class="footer-resolution">best viewed at 1024×768</span>
    </div>
    <div class="footer-body container">
      <div class="footer-left">
        <p class="footer-brand">
          <span class="glow-cyan">yourname</span
          ><span class="glow-magenta">.dev</span>
        </p>
        <p class="footer-copy">
          Hand-crafted with ♥ and too much caffeine.<br />
          Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
          No tracking. No cookies. Just vibes.
        </p>
        <div class="footer-badges">
          <span class="retro-badge">HTML5</span>
          <span class="retro-badge">CSS3</span>
          <span class="retro-badge">Netscape Navigator™ Compatible</span>
        </div>
      </div>

      <div class="footer-center">
        <HitCounter />
      </div>

      <div class="footer-right">
        <p class="footer-nav-label">// links</p>
        <ul class="footer-social" role="list">
          {socials.map(({ label, href, icon }) => (
            <li>
              <a href={href} aria-label={label}
                 {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
                <span class="social-icon" aria-hidden="true">{icon}</span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} yourname · All rights reserved · <a href="/rss.xml">RSS</a> · <a href="/sitemap-index.xml">Sitemap</a></p>
      <p class="footer-ascii" aria-hidden="true">[ ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓ 100% ]</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .footer-chrome { border-top: 2px solid var(--color-border-bright); }

  .footer-titlebar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-6);
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-dim);
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-lime);
    box-shadow: var(--glow-lime);
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 4px var(--color-lime); }
    50% { box-shadow: var(--glow-lime); }
  }

  .footer-body {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-6);
    align-items: start;
  }

  .footer-brand {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    font-weight: bold;
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .footer-copy a { color: var(--color-cyan-dim); }
  .footer-copy a:hover { color: var(--color-cyan); }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .retro-badge {
    display: inline-block;
    padding: 2px 6px;
    border: 1px solid var(--color-border-bright);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-dim);
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: var(--space-2);
  }

  .footer-nav-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-magenta);
    margin-bottom: var(--space-4);
    letter-spacing: 0.1em;
  }

  .footer-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-social a:hover {
    color: var(--color-cyan);
    text-decoration: none;
  }

  .social-icon {
    color: var(--color-text-dim);
    font-size: var(--text-xs);
    min-width: 3em;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .footer-bottom a { color: var(--color-cyan-dim); }
  .footer-bottom a:hover { color: var(--color-cyan); text-decoration: none; }

  .footer-ascii {
    color: var(--color-lime-dim);
    font-size: 0.65rem;
  }

  @media (max-width: 768px) {
    .footer-body {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-center { padding: 0; }

    .footer-social { align-items: center; }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
