---
const year = new Date().getFullYear();

const socials = [
  { label: 'GitHub',   href: 'https://github.com/yourname',     icon: '[gh]'  },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourname', icon: '[in]'  },
  { label: 'Email',    href: 'mailto:hello@dachava.dev',         icon: '[✉]'   },
  { label: 'RSS',      href: '/rss.xml',                         icon: '[rss]' },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner container">

    <!-- Brand -->
    <p class="footer-brand"><span class="glow-cyan">dachava</span><span class="glow-magenta">.dev</span></p>

    <!-- 88×31 retro banner slots -->
    <div class="footer-banners" aria-hidden="true">
      <span class="banner-placeholder">[ 88×31 ]</span>
      <span class="banner-placeholder">[ 88×31 ]</span>
      <span class="banner-placeholder">[ 88×31 ]</span>
    </div>

    <!-- Links + copyright -->
    <nav class="footer-links" aria-label="Footer links">
      {socials.map(({ label, href, icon }) => (
        <a href={href} aria-label={label}
           {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
          {icon}
        </a>
      ))}
      <span class="footer-divider" aria-hidden="true">·</span>
      <a href="/sitemap-index.xml">sitemap</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <span class="footer-copy">© {year}</span>
    </nav>

  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-16);
    border-top: 2px solid var(--color-border-bright);
    background: var(--color-surface);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    flex-wrap: wrap;
  }

  /* Brand */
  .footer-brand {
    font-size: var(--text-base);
    font-weight: bold;
    white-space: nowrap;
    line-height: 31px;
    margin: 0;
    padding: 0;
  }

  /* Banners */
  .footer-banners {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .banner-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 31px;
    border: 1px dashed var(--color-border-bright);
    font-size: 0.55rem;
    color: var(--color-text-dim);
    opacity: 0.35;
    flex-shrink: 0;
  }

  /* Links */
  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover { color: var(--color-cyan); }

  .footer-divider,
  .footer-sep { color: var(--color-border-bright); }

  .footer-copy { color: var(--color-text-dim); }

  @media (max-width: 640px) {
    .footer-banners { display: none; }
    .footer-links { margin-left: 0; }
  }
</style>
