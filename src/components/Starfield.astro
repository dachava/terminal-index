---
// Animated starfield background — CSS + minimal canvas
---
<canvas id="starfield" aria-hidden="true"></canvas>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.6;
  }

  [data-theme="light"] #starfield {
    opacity: 0.15;
  }
</style>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  interface Star {
    x: number;
    y: number;
    z: number;
    px: number;
    py: number;
  }

  let W = window.innerWidth;
  let H = window.innerHeight;
  canvas.width = W;
  canvas.height = H;

  const STAR_COUNT = 180;
  const SPEED = 0.4;
  const stars: Star[] = [];

  function randomStar(): Star {
    return {
      x: Math.random() * W - W / 2,
      y: Math.random() * H - H / 2,
      z: Math.random() * W,
      px: 0,
      py: 0,
    };
  }

  for (let i = 0; i < STAR_COUNT; i++) {
    stars.push(randomStar());
  }

  function draw() {
    ctx.fillStyle = 'rgba(0,0,0,0)';
    ctx.clearRect(0, 0, W, H);

    const cx = W / 2;
    const cy = H / 2;

    for (const star of stars) {
      star.z -= SPEED;
      if (star.z <= 0) {
        Object.assign(star, randomStar());
        star.z = W;
      }

      const sx = (star.x / star.z) * W + cx;
      const sy = (star.y / star.z) * W + cy;

      if (sx < 0 || sx > W || sy < 0 || sy > H) {
        Object.assign(star, randomStar());
        star.z = W;
        continue;
      }

      const radius = Math.max(0.5, (1 - star.z / W) * 2);
      const alpha  = (1 - star.z / W) * 0.85 + 0.1;

      // Trail
      const trailX = (star.px || sx);
      const trailY = (star.py || sy);

      ctx.beginPath();
      ctx.moveTo(trailX, trailY);
      ctx.lineTo(sx, sy);
      ctx.strokeStyle = `rgba(0, 245, 255, ${alpha * 0.3})`;
      ctx.lineWidth = radius * 0.5;
      ctx.stroke();

      // Star dot
      ctx.beginPath();
      ctx.arc(sx, sy, radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200, 240, 255, ${alpha})`;
      ctx.fill();

      star.px = sx;
      star.py = sy;
    }

    requestAnimationFrame(draw);
  }

  draw();

  window.addEventListener('resize', () => {
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W;
    canvas.height = H;
  });
</script>
