---
import BaseLayout from '../layouts/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';

const skills = {
  Languages:  ['TypeScript', 'JavaScript', 'Rust', 'Python', 'SQL', 'Bash'],
  Frontend:   ['Astro', 'React', 'CSS / Custom Properties', 'SVG', 'Canvas API', 'WebAssembly'],
  Backend:    ['Node.js', 'Express', 'PostgreSQL', 'SQLite', 'Redis'],
  Tools:      ['Git', 'Linux', 'Docker', 'Vim / Neovim', 'tmux'],
};

const timeline = [
  {
    year: '2024',
    title: 'Senior Software Engineer',
    org: 'Some Cool Company',
    desc: 'Building developer tooling and internal platforms. Lots of TypeScript, some Rust, occasional CSS therapy.',
  },
  {
    year: '2022',
    title: 'Software Engineer',
    org: 'Another Place',
    desc: 'Full-stack web development. React frontend, Node.js APIs, PostgreSQL. First time touching production at scale.',
  },
  {
    year: '2020',
    title: 'Junior Developer',
    org: 'Agency Life Inc.',
    desc: 'Client websites, WordPress customization, first taste of actually shipping things people use.',
  },
  {
    year: '2019',
    title: 'CS Degree',
    org: 'State University',
    desc: 'Graduated. Learned algorithms, forgot most of them. Kept the problem-solving instincts.',
  },
];

const contacts = [
  { label: 'Email',    href: 'mailto:hello@yourname.dev',         icon: '✉',  desc: 'hello@yourname.dev'   },
  { label: 'GitHub',   href: 'https://github.com/yourname',       icon: '◎',  desc: '@yourname'            },
  { label: 'Twitter',  href: 'https://twitter.com/yourname',      icon: '✦',  desc: '@yourname'            },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourname',  icon: '□',  desc: 'in/yourname'          },
  { label: 'RSS',      href: '/rss.xml',                          icon: '◈',  desc: '/rss.xml'             },
];
---

<BaseLayout
  title="About"
  description="Software engineer, web developer, digital packrat. This is the about page."
>
  <div class="about-page container">
    <header class="page-header">
      <div class="page-header-prefix" aria-hidden="true">$ cat ~/about.txt</div>
      <h1 class="page-title">About</h1>
    </header>

    <!-- Profile card -->
    <section class="profile-section" aria-labelledby="profile-heading">
      <RetroWindow title="profile.json" class="profile-card">
        <div class="profile-inner">
          <div class="profile-avatar" aria-hidden="true">
            <div class="avatar-box">
              <pre class="avatar-art">
┌─────────────┐
│  ▒▒▒▒▒▒▒▒  │
│ ▒░░░░░░░░▒ │
│ ▒░ ◉  ◉ ░▒ │
│ ▒░   ▽   ░▒ │
│ ▒░ ╰──╯  ░▒ │
│  ▒▒▒▒▒▒▒▒  │
└─────────────┘</pre>
              <p class="avatar-status"><span class="status-dot-green" aria-hidden="true">●</span> available for coffee chats</p>
            </div>
          </div>

          <div class="profile-bio">
            <h2 id="profile-heading" class="profile-name">
              <span class="glow-cyan">Your</span> <span class="glow-magenta">Name</span>
            </h2>
            <p class="profile-handle">@yourname</p>
            <div class="profile-text">
              <p>
                I'm a software engineer with a deep appreciation for the craft of making things.
                I care about code that's readable, interfaces that feel good, and websites that
                are fast by default.
              </p>
              <p>
                My aesthetic sense was formed by early 2000s web design — not the bad parts (Comic Sans,
                auto-playing MIDI) but the good parts: the sense that websites were <em>places</em>, made
                by people, for people. I try to bring that spirit to what I build now.
              </p>
              <p>
                When I'm not at a keyboard, I'm probably reading (old computer history, sci-fi, the
                occasional cookbook), messing with vintage hardware, or trying to keep my plant alive.
              </p>
            </div>
          </div>
        </div>
      </RetroWindow>
    </section>

    <!-- Skills inventory -->
    <section class="skills-section" aria-labelledby="skills-heading">
      <div class="section-heading">
        <h2 id="skills-heading">skills &amp; tools</h2>
      </div>

      <div class="skills-grid" role="list">
        {Object.entries(skills).map(([category, items]) => (
          <RetroWindow title={`${category.toLowerCase()}.txt`} class="skill-window">
            <div class="skill-list">
              {items.map((skill, i) => (
                <div class="skill-row">
                  <span class="skill-name">{skill}</span>
                  <div class="skill-bar" aria-hidden="true">
                    <div
                      class="skill-fill"
                      style={`width: ${Math.max(60, 100 - i * 8)}%`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </RetroWindow>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section" aria-labelledby="timeline-heading">
      <div class="section-heading">
        <h2 id="timeline-heading">experience</h2>
      </div>

      <ol class="timeline" role="list">
        {timeline.map((item, i) => (
          <li class="timeline-item">
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-connector" aria-hidden="true">
              <span class="timeline-dot"></span>
              {i < timeline.length - 1 && <span class="timeline-line"></span>}
            </div>
            <div class="timeline-content">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-org">{item.org}</p>
              <p class="timeline-desc">{item.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Contact -->
    <section class="contact-section" aria-labelledby="contact-heading">
      <div class="section-heading">
        <h2 id="contact-heading">contact</h2>
      </div>

      <RetroWindow title="contact_book.txt">
        <ul class="contact-list" role="list">
          {contacts.map(({ label, href, icon, desc }) => (
            <li class="contact-item">
              <a
                href={href}
                class="contact-link"
                aria-label={`${label}: ${desc}`}
                {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
              >
                <span class="contact-icon" aria-hidden="true">{icon}</span>
                <span class="contact-label">{label}</span>
                <span class="contact-desc">{desc}</span>
              </a>
            </li>
          ))}
        </ul>
      </RetroWindow>
    </section>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-12) 0 var(--space-16);
    max-width: 900px;
  }

  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-header-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    margin-bottom: var(--space-2);
  }

  .page-title {
    font-size: var(--text-4xl);
    color: var(--color-lime);
    text-shadow: var(--glow-lime);
  }

  /* ── Profile ── */
  .profile-section { margin-bottom: var(--space-16); }
  .profile-card { width: 100%; }

  .profile-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .avatar-art {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.3;
    color: var(--color-cyan-dim);
    background: none;
    border: none;
    padding: 0;
    white-space: pre;
    text-shadow: var(--glow-cyan);
  }

  .avatar-status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-dim);
    text-align: center;
    margin-top: var(--space-3);
  }

  .status-dot-green {
    color: var(--color-lime);
    text-shadow: var(--glow-lime);
  }

  .profile-name {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .profile-handle {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-dim);
    margin-bottom: var(--space-6);
  }

  .profile-text p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin-bottom: var(--space-4);
    max-width: 60ch;
  }

  /* ── Skills ── */
  .skills-section { margin-bottom: var(--space-16); }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .skill-row {
    display: grid;
    grid-template-columns: 150px 1fr;
    align-items: center;
    gap: var(--space-3);
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .skill-bar {
    height: 6px;
    background: var(--color-surface-3);
    border-radius: 3px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(to right, var(--color-cyan-dim), var(--color-cyan));
    border-radius: 3px;
    transition: width 1s ease;
  }

  /* ── Timeline ── */
  .timeline-section { margin-bottom: var(--space-16); }

  .timeline {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 60px 32px 1fr;
    gap: 0 var(--space-4);
    padding-bottom: var(--space-8);
  }

  .timeline-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-amber);
    text-shadow: var(--glow-amber);
    padding-top: 4px;
    text-align: right;
  }

  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-magenta);
    box-shadow: var(--glow-magenta);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .timeline-line {
    flex: 1;
    width: 1px;
    background: var(--color-border);
    margin-top: var(--space-2);
    margin-bottom: calc(-1 * var(--space-2));
  }

  .timeline-title {
    font-size: var(--text-base);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .timeline-org {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-cyan);
    margin-bottom: var(--space-3);
  }

  .timeline-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ── Contact ── */
  .contact-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-link {
    display: grid;
    grid-template-columns: 24px 100px 1fr;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .contact-link:hover {
    background: var(--color-surface-2);
    text-decoration: none;
  }

  .contact-icon {
    font-size: 1.1rem;
    color: var(--color-cyan);
    text-align: center;
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .contact-desc {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .profile-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .avatar-box { display: flex; flex-direction: column; align-items: center; }

    .profile-text p { max-width: none; }

    .timeline-item {
      grid-template-columns: 50px 24px 1fr;
      gap: 0 var(--space-3);
    }

    .skill-row { grid-template-columns: 120px 1fr; }
  }
</style>
