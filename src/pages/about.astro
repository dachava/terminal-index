---
import BaseLayout from '../layouts/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';
import AvatarFrame from '../components/AvatarFrame.astro';
import '../styles/about.css';

const skills = {
  Languages:  ['TypeScript', 'JavaScript', 'Rust', 'Python', 'SQL', 'Bash'],
  Frontend:   ['Astro', 'React', 'CSS / Custom Properties', 'SVG', 'Canvas API', 'WebAssembly'],
  Backend:    ['Node.js', 'Express', 'PostgreSQL', 'SQLite', 'Redis'],
  Tools:      ['Git', 'Linux', 'Docker', 'Vim / Neovim', 'tmux'],
};

const timeline = [
  {
    year: '2024',
    title: 'Senior Software Engineer',
    org: 'Some Cool Company',
    desc: 'Building developer tooling and internal platforms. Lots of TypeScript, some Rust, occasional CSS therapy.',
  },
  {
    year: '2022',
    title: 'Software Engineer',
    org: 'Another Place',
    desc: 'Full-stack web development. React frontend, Node.js APIs, PostgreSQL. First time touching production at scale.',
  },
  {
    year: '2020',
    title: 'Junior Developer',
    org: 'Agency Life Inc.',
    desc: 'Client websites, WordPress customization, first taste of actually shipping things people use.',
  },
  {
    year: '2019',
    title: 'CS Degree',
    org: 'State University',
    desc: 'Graduated. Learned algorithms, forgot most of them. Kept the problem-solving instincts.',
  },
];

const contacts = [
  { host: 'github.com',    href: 'https://github.com/dachava',       reply: '@dachava',          ms: 4 },
  { host: 'linkedin.com',  href: 'https://linkedin.com/in/diegochavab', reply: 'in/diegochavab', ms: 12 },
  { host: 'dachava.dev',   href: 'mailto:hello@dachava.dev',         reply: 'hello@dachava.dev', ms: 1  },
  { host: 'rss',           href: '/rss.xml',                         reply: '/rss.xml',          ms: 0  },
];
---

<BaseLayout
  title="About"
  description="Software engineer, web developer, digital packrat. This is the about page."
>
  <div class="about-page container">
    <header class="page-header">
      <div class="page-header-prefix" aria-hidden="true">$ ./about.sh</div>
      <h1 class="page-title">About</h1>
    </header>

    <!-- Profile — character sheet layout -->
    <section class="profile-section" aria-labelledby="profile-heading">

      <!-- Top row: avatar + stat card -->
      <div class="profile-top">

        <!-- Avatar (standalone, no window chrome) -->
        <div class="profile-avatar">
          <AvatarFrame src="/images/about.png" lightSrc="/images/about-light.png" alt="Diego Chavarría" size={180} />
        </div>

        <!-- Stats — raw terminal output, no window chrome -->
        <div class="stat-block">
          <h2 id="profile-heading" class="stat-name">
            <span class="glow-cyan">Diego</span> <span class="glow-magenta">Chavarría</span>
          </h2>
          <p class="stat-handle">@divinity</p>
          <div class="stat-divider" aria-hidden="true"></div>
          <dl class="stats">
            <div class="stat-row">
              <dt class="stat-key">class</dt>
              <dd class="stat-val">Software Engineer</dd>
            </div>
            <div class="stat-row">
              <dt class="stat-key">location</dt>
              <dd class="stat-val">San José, CRC</dd>
            </div>
            <div class="stat-row">
              <dt class="stat-key">focus</dt>
              <dd class="stat-val">cloud · systems · security</dd>
            </div>
            <div class="stat-row">
              <dt class="stat-key">status</dt>
              <dd class="stat-val stat-status"><span class="status-pip" aria-hidden="true"></span>online</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Bio panel -->
      <RetroWindow title="bio.txt" class="bio-card">
        <div class="profile-text" id="profile-heading">
          <p>
            I'm a software engineer with a deep appreciation for the craft of making things.
            I care about code that's readable, interfaces that feel good, and systems that
            are fast by default.
          </p>
          <p>
            My aesthetic sense was formed by early 2000s web design — not the bad parts (Comic Sans,
            auto-playing MIDI) but the good parts: the sense that websites were <em>places</em>, made
            by people, for people. I try to bring that spirit to what I build now.
          </p>
          <p>
            When I'm not at a keyboard I'm probably reading about old computers, listening to black metal,
            playing something from 2003, or trying to keep my plant alive.
          </p>
        </div>
      </RetroWindow>

    </section>

    <!-- Skills inventory -->
    <section class="skills-section" aria-labelledby="skills-heading">
      <div class="skills-prompt" aria-hidden="true">
        <span class="prompt-user">divinity</span><span class="prompt-at">@</span><span class="prompt-host">dachava.dev</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        <span class="prompt-cmd">tree ~/skills</span>
      </div>

      <div class="skills-tree" role="list" aria-label="Skills and tools">
        <div class="tree-root" aria-hidden="true">skills/</div>
        {Object.entries(skills).map(([category, items], ci) => {
          const isLast = ci === Object.entries(skills).length - 1;
          return (
            <div class="tree-category" role="listitem">
              <span class="tree-branch" aria-hidden="true">{isLast ? '└──' : '├──'}</span>
              <span class="tree-cat-name">{category.toLowerCase()}/</span>
              <div class="tree-chips">
                {items.map(skill => (
                  <span class="skill-chip">{skill}</span>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section" aria-labelledby="timeline-heading">
      <div class="section-heading">
        <h2 id="timeline-heading">experience</h2>
      </div>

      <ol class="timeline" role="list">
        {timeline.map((item, i) => (
          <li class="timeline-item">
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-connector" aria-hidden="true">
              <span class="timeline-dot"></span>
              {i < timeline.length - 1 && <span class="timeline-line"></span>}
            </div>
            <div class="timeline-content">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-org">{item.org}</p>
              <p class="timeline-desc">{item.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Contact -->
    <section class="contact-section" aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="sr-only">Contact</h2>

      <div class="ping-prompt" aria-hidden="true">
        <span class="prompt-user">divinity</span><span class="prompt-at">@</span><span class="prompt-host">dachava.dev</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        <span class="prompt-cmd">ping -c 1 {contacts.map(c => c.host).join(' ')}</span>
      </div>

      <ul class="ping-list">
        {contacts.map(({ host, href, reply, ms }, i) => (
          <li class="ping-row" style={`animation-delay:${i * 120}ms`}>
            <a
              href={href}
              class="ping-link"
              aria-label={reply}
              {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            >
              <span class="ping-seq" aria-hidden="true">64 bytes from</span>
              <span class="ping-host">{host}</span>
              <span class="ping-sep" aria-hidden="true">:</span>
              <span class="ping-reply">{reply}</span>
              <span class="ping-spacer" aria-hidden="true"></span>
              <span class="ping-time" aria-hidden="true">time={ms}ms</span>
              <span class="ping-open">open →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

