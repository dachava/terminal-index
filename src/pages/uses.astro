---
import BaseLayout from '../layouts/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';
import AvatarFrame from '../components/AvatarFrame.astro';
import '../styles/uses.css';

const gear = [
  { section: 'hardware' },
  { key: 'mobo',      val: 'MSI MEG X570 Ace (MS-7C35)' },
  { key: 'cpu',       val: '12-Core AMD Ryzen 9 5900X, 4819 MHz (48.75 x 99)' },
  { key: 'ram',       val: '32 GB DDR4 3600' },
  { key: 'gpu',       val: 'NVIDIA GeForce RTX 5070 Ti (16303 MB)' },
  { key: 'display',   val: 'Gigabyte M27Q [27" IPS LCD]' },
  { key: 'mouse',     val: 'RAZER Viper Ultimate' },
  { key: 'audio',     val: 'Solid State Logic SSL 2+' },
  { section: 'software' },
  { key: 'browser',   val: 'LibreWolf' },
  { key: 'editor',    val: 'Neovim (LazyVim)' },
  { key: 'terminal',  val: 'MobaXterm + Guake' },
  { key: 'notes',     val: 'Joplin' },
  { key: 'pdf',       val: 'SumatraPDF' },
  { key: 'music',     val: 'WACUP' },
];
---

<BaseLayout
  title="Uses"
  description="Hardware, software, and tools in Diego's daily driver setup."
>
  <div class="uses-page container">
    <header class="page-header">
      <div class="page-header-prefix" aria-hidden="true">$ neofetch --config ~/.config/uses.conf</div>
      <h1 class="page-title">
        <span class="glow-cyan">✦</span> Uses
      </h1>
      <p class="page-description">
        The hardware and software I use day-to-day. Inspired by
        <a href="https://uses.tech" target="_blank" rel="noopener noreferrer">uses.tech</a>.
        <span style="white-space: nowrap;">Last updated April 2026.</span>
      </p>
    </header>

    <div class="uses-grid">

      <!-- Neofetch identity panel with avatar -->
      <RetroWindow title="neofetch" class="neofetch-window">
        <div class="neofetch-layout">

          <div class="neofetch-avatar-wrap">
            <AvatarFrame
              src="/images/avatar.png"
              lightSrc="/images/avatar-light.png"
              alt="Diego Chavarría"
              size={140}
            />
            <p class="avatar-credit">
              art by <a href="https://16colo.rs/pack/mist0223/MM-BORNDIGITAL.ANS" class="credit-link" target="_blank" rel="noopener noreferrer">Mavenmob</a>
            </p>
          </div>

          <dl class="neofetch-info">
            <div class="nf-row"><dt>user</dt><dd><span class="glow-cyan">621</span>@dachava.dev</dd></div>
            <div class="nf-divider" aria-hidden="true"></div>
            <div class="nf-row"><dt>os</dt><dd>Devuan Excalibur 6</dd></div>
            <div class="nf-row"><dt>kernel</dt><dd>Linux 6.1 x86_64</dd></div>
            <div class="nf-row"><dt>init</dt><dd>sysvinit</dd></div>
            <div class="nf-row"><dt>pid 1</dt><dd>/sbin/init</dd></div>
            <div class="nf-row"><dt>wm</dt><dd>openbox</dd></div>
            <div class="nf-row"><dt>shell</dt><dd>zsh</dd></div>
            <div class="nf-row"><dt>packages</dt><dd>dpkg</dd></div>
            <div class="nf-row"><dt>editor</dt><dd>nvim</dd></div>
            <div class="nf-row"><dt>uptime</dt><dd>eternal</dd></div>
            <div class="nf-colors" aria-label="Terminal color palette">
              {Array.from({ length: 8 }).map((_, i) => (
                <span class={`nf-color nf-color-${i}`}></span>
              ))}
            </div>
          </dl>
        </div>
      </RetroWindow>

      <!-- Combined gear list -->
      <RetroWindow title="gear.conf" class="gear-window">
        <dl class="gear-list">
          {gear.map((item) =>
            'section' in item ? (
              <div class="gear-section-label" aria-hidden="true">// {item.section}</div>
            ) : (
              <div class="spec-row">
                <dt class="spec-key">{item.key}</dt>
                <dd class="spec-val">{item.val}</dd>
              </div>
            )
          )}
        </dl>
      </RetroWindow>

    </div>

    <footer class="uses-footer">
      <p class="uses-footer-note">
        <span class="glow-text-dim" aria-hidden="true">$</span>
        No affiliate links, wish I could get paid though.
      </p>
    </footer>
  </div>
</BaseLayout>
